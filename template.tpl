___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const createQueue = require('createQueue');
const copyFromWindow = require('copyFromWindow');
const injectScript = require('injectScript');
const logToConsole = require('logToConsole');
const makeTableMap = require('makeTableMap');

const trackType = data.trackType;
const trackerUrl = data.trackerUrl || 'https://advz.it/pixel.js';
const debugMode = data.debugMode;

// createQueue mirrors the array-queue pattern in the Adverzia snippet: it
// creates window.advz as a queueing stub if it doesn't already exist, and
// returns a function that pushes onto that queue either way.
const advz = createQueue('advz');

function log(message, value) {
  if (debugMode) {
    logToConsole('[Adverzia]', message, value);
  }
}

function eventData() {
  return makeTableMap(data.eventData, 'key', 'value') || {};
}

function fireTrack() {
  if (trackType === 'pageview') {
    const initOptions = {};
    if (data.cookieDomain) {
      initOptions.cookieDomain = data.cookieDomain;
    }
    advz('init', data.campaignId, initOptions);
    advz('event', 'pageload');
    log('init + pageload', data.campaignId);
  } else if (trackType === 'conversion') {
    const ed = eventData();
    advz('event', 'conversion', ed);
    log('conversion', ed);
  } else if (trackType === 'customer') {
    const ed = eventData();
    advz('event', 'customer', ed);
    log('customer', ed);
  } else if (trackType === 'custom') {
    const ed = eventData();
    advz('event', data.customEventName, ed);
    log(data.customEventName, ed);
  }

  data.gtmOnSuccess();
}

// pixel.js is idempotent (it no-ops if window.advz is already set up by a
// prior tag on the page), but we still avoid re-injecting the <script> tag
// once it has already loaded.
if (copyFromWindow('advz') && copyFromWindow('advz').process) {
  fireTrack();
} else {
  injectScript(trackerUrl, fireTrack, function () {
    log('failed to load tracker script', trackerUrl);
    data.gtmOnFailure();
  }, trackerUrl);
}


