___TESTS___

scenarios:
- name: Page View injects script then fires init + pageload
  code: |-
    const mockData = {
      trackType: 'pageview',
      campaignId: 'ID-TEST1234',
      trackerUrl: 'https://advz.it/pixel.js'
    };

    mock('copyFromWindow', function() { return undefined; });

    let injectedUrl;
    mock('injectScript', function(url, onSuccess) {
      injectedUrl = url;
      onSuccess();
    });

    const calls = [];
    mock('createQueue', function(key) {
      return function(a, b, c) {
        calls.push([a, b, c]);
      };
    });

    runCode(mockData);

    assertThat(injectedUrl).isEqualTo('https://advz.it/pixel.js');
    assertThat(calls[0][0]).isEqualTo('init');
    assertThat(calls[0][1]).isEqualTo('ID-TEST1234');
    assertThat(calls[1][0]).isEqualTo('event');
    assertThat(calls[1][1]).isEqualTo('pageload');
    assertApi('gtmOnSuccess').wasCalled();
- name: Conversion skips re-injection when advz is already loaded
  code: |-
    const mockData = {
      trackType: 'conversion',
      eventData: [
        {key: 'order_id', value: '123'},
        {key: 'amount', value: '4999'}
      ]
    };

    mock('copyFromWindow', function(key) {
      if (key === 'advz') {
        return {process: function() {}};
      }
      return undefined;
    });

    let injectCalled = false;
    mock('injectScript', function() {
      injectCalled = true;
    });

    const calls = [];
    mock('createQueue', function(key) {
      return function(a, b, c) {
        calls.push([a, b, c]);
      };
    });

    runCode(mockData);

    assertThat(injectCalled).isFalse();
    assertThat(calls[0][0]).isEqualTo('event');
    assertThat(calls[0][1]).isEqualTo('conversion');
    assertThat(calls[0][2]).isEqualTo({order_id: '123', amount: '4999'});
    assertApi('gtmOnSuccess').wasCalled();
- name: Script injection failure calls gtmOnFailure
  code: |-
    const mockData = {
      trackType: 'pageview',
      campaignId: 'ID-1'
    };

    mock('copyFromWindow', function() { return undefined; });
    mock('injectScript', function(url, onSuccess, onFailure) {
      onFailure();
    });
    mock('createQueue', function(key) {
      return function() {};
    });

    runCode(mockData);

    assertApi('gtmOnFailure').wasCalled();
    assertApi('gtmOnSuccess').wasNotCalled();


